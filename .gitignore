frontend/web-build/
frontend/ios/
frontend/android/

# Backend
backend/uploads/
backend/error.log
backend/vendor/

# Backend database dumps (contain real user data / password hashes — NEVER commit)
backend/database/*.sql
# ...except the reference-data seed (categories/jobs/skills/languages — no PII, needed for deploys)
!backend/database/ref_seed.sql

# Internal working notes — NOT for the public repo (security posture / stale guides)
/SECURITY_NOTES_*.md
/GUIDE_didit_valid_id_verification.md

# User-uploaded content (chat attachments, etc.)
uploads/
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
frontend/.cursor/
.claude/settings.local.json

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.log

# Environment variables (NEVER commit these!)
.env
.env.local
.env.*.local



# Portable host config (DB creds + API key) — NEVER commit
backend/config.local.php

# Local email debug tool — must never reach the server
backend/test_email.php

# Claude Code local permission allowlist — machine-specific paths, not shareable
.claude/settings.json

# Local one-time backfill artifact (not needed in the repo)
backend/database/job_titles_before_backfill.json
